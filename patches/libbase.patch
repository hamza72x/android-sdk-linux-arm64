--- a/logging.cpp
+++ b/logging.cpp
@@ -48,6 +48,9 @@
 #else
 #include <sys/types.h>
 #include <unistd.h>
+// __builtin_available(android X, *) is a Clang built-in for Android API level checks.
+// On non-Android Linux, these code paths should always take the fallback (else) branch.
+#define __builtin_available(...) false
 #endif
 
 #include <android-base/file.h>
