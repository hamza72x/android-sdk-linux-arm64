+// GCC 15 errors on flexible array members not at end of struct.
+// usbdevfs_urb has a zero-length flexible array that is never used.
+// Wrap it in an aligned byte buffer to avoid the error.
+struct urb_storage {
+    alignas(usbdevfs_urb) char buf[sizeof(usbdevfs_urb)];
+    urb_storage() { memset(buf, 0, sizeof(buf)); }
+    usbdevfs_urb* get() { return reinterpret_cast<usbdevfs_urb*>(buf); }
+    usbdevfs_urb* operator->() { return get(); }
+    usbdevfs_urb& operator*() { return *get(); }
+};
